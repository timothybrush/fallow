{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "root=$(git rev-parse --show-toplevel 2>/dev/null || pwd); python3 \"$root/.claude/hooks/pre-bash-guard.py\"",
            "statusMessage": "Checking fallow agent command guard..."
          },
          {
            "type": "command",
            "command": "if jq -r '.tool_input.command' | grep -q '^git commit'; then cargo fmt --all 2>/dev/null; typos; fi",
            "statusMessage": "Pre-commit: formatting and typo check..."
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 scripts/scan-hidden-unicode.py --mode agent 2>&1 || true",
            "statusMessage": "Scanning agent-instruction files for hidden unicode..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "root=$(git rev-parse --show-toplevel 2>/dev/null || pwd); node \"$root/scripts/check-comment-quality.mjs\" --working-tree --claude-hook",
            "statusMessage": "Checking added comments for routine narration..."
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "python3.13 \"$CLAUDE_PROJECT_DIR\"/.claude/tt-statusline.py 2>/dev/null || python3 \"$CLAUDE_PROJECT_DIR\"/.claude/tt-statusline.py 2>/dev/null || python \"$CLAUDE_PROJECT_DIR\"/.claude/tt-statusline.py",
    "refreshInterval": 5
  },
  "enabledPlugins": {
    "trigger-tree@trigger-tree": true
  },
  "extraKnownMarketplaces": {
    "trigger-tree": {
      "source": {
        "source": "github",
        "repo": "Hedde/trigger_tree",
        "ref": "v1.23.2"
      }
    }
  }
}
