{
  "name": "fallow-repo-tools",
  "private": true,
  "type": "module",
  "scripts": {
    "commitlint": "commitlint",
    "verify": "node scripts/verify-repo.mjs --fast",
    "verify:fast": "node scripts/verify-repo.mjs --fast",
    "verify:full": "node scripts/verify-repo.mjs --full",
    "generate:contracts": "node scripts/generate-all.mjs",
    "generate:contracts:check": "node scripts/generate-all.mjs --check",
    "generate:all": "node scripts/generate-all.mjs",
    "generate:all:check": "node scripts/generate-all.mjs --check",
    "check:contract-surfaces": "node scripts/check-contract-surfaces.mjs --github-actions .github/workflows/ci.yml",
    "check:ci-summary-rows": "node scripts/check-ci-summary-rows.mjs",
    "check:crate-boundaries": "node scripts/check-crate-boundaries.mjs",
    "scaffold:analyzer": "node scripts/scaffold-analyzer-plan.mjs",
    "conformance:public-smoke": "node scripts/public-smoke-conformance.mjs",
    "smoke:styling-corpus": "node scripts/styling-corpus-smoke.mjs",
    "smoke:styling-prs": "node scripts/styling-pr-smoke.mjs",
    "lint:js": "oxlint --disable-nested-config npm benchmarks crates/napi .github/scripts editors/vscode/src viz-frontend/src scripts commitlint.config.mjs",
    "fmt:js": "oxfmt --disable-nested-config npm benchmarks crates/napi .github/scripts editors/vscode/src viz-frontend/src scripts commitlint.config.mjs",
    "fmt:js:check": "oxfmt --check --disable-nested-config npm benchmarks crates/napi .github/scripts editors/vscode/src viz-frontend/src scripts commitlint.config.mjs"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "devDependencies": {
    "@commitlint/cli": "21.2.1",
    "@commitlint/config-conventional": "21.2.0",
    "@tanstack/intent": "0.3.5",
    "oxfmt": "0.59.0",
    "oxlint": "1.74.0"
  }
}
