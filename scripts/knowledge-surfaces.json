    "ignoredWorktreePrefixes": [
      {
        "path": "docs/superpowers/",
        "reason": "Legacy local workflow artifacts are ignored and are not maintainer documentation."
      }
    ]
  },
  "skills": {
    "canonicalRoot": ".agents/skills",
    "adapterRoots": [
      {
        "client": "claude",
        "path": ".claude/skills",
        "mode": "generated"
      }
    ],
    "generator": "scripts/generate-agent-adapters.mjs",
    "checkCommand": "npm run check:agent-adapters"
  },
  "hostRules": [
    {
      "client": "claude",
      "root": ".claude/rules",
      "mode": "scoped-router"
    }
  ],
  "generatedPathContracts": [
    {
      "path": "benchmarks/fixtures/real-world",
      "setupDocument": "BENCHMARKS.md",
      "setupCommand": [
        "npm",
        "--prefix",
        "benchmarks",
        "run",
        "download-fixtures"
      ]
    }
  ],
  "externalSources": [
    {
      "repository": "fallow-rs/docs",
      "role": "canonical-public-user-documentation",
      "direction": "public-to-consumer",
      "revisionSource": "public-content-manifest.json plus consumer lock",
      "allowedRoot": ".",
      "processor": {
        "kind": "generator",
        "entrypoint": "scripts/public-content.mjs"
      },
      "checkCommand": [
        "npm",
        "run",
        "check"
      ]
    },
    {
      "repository": "fallow-rs/fallow-skills",
      "role": "portable-public-skill-packaging",
      "direction": "canonical-contract-to-public-consumer",
      "revisionSource": "source-lock.json#commit",
      "allowedRoot": "npm/fallow/skills/fallow",
      "processor": {
        "kind": "validator",
        "entrypoint": "scripts/check-source-contract.mjs"
      },
      "checkCommand": [
        "node",
        "scripts/check-source-contract.mjs"
      ]
    },
    {
      "repository": "fallow-rs/fallow-cov-protocol",
      "role": "public-cloud-facing-runtime-contract",
      "direction": "public-to-consumer",
      "revisionSource": "Cargo.lock",
      "allowedRoot": "src",
      "processor": {
        "kind": "none"
      },
      "checkCommand": [
        "cargo",
        "test",
        "--all-targets"
      ]
    }
  ],
  "trustBoundary": {
    "automatedPrivateToPublic": false,
    "publicPromotion": "sanitized-reviewed-rewrite",
    "forbiddenRoutePrefixes": [
      ".internal/",
      "internal/",
      "decisions/"
    ],
    "forbiddenReferencePrefixes": [
      ".internal/",
      "internal/",
      "decisions/"
    ],
    "forbiddenReferencePatterns": [
      {
        "pattern": "/Users/",
        "reason": "Machine-local absolute paths are not portable."
      },
      {
        "pattern": "~/.claude/",
        "reason": "Durable knowledge cannot depend on host-local Claude state."
      },
      {
        "pattern": "~/Sites/",
        "reason": "Durable knowledge cannot depend on a maintainer checkout layout."
      }
    ],
    "forbiddenRepositories": [
      "fallow-rs/fallow-cloud"
    ]
  }
}
