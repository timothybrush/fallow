{
  "schemaVersion": 2,
  "entryPoints": [
    {
      "path": "AGENTS.md",
      "client": "codex",
      "routes": [
        "docs/README.md",
        "docs/development/task-context-map.md",
        ".agents/skills"
      ]
    },
    {
      "path": "CLAUDE.md",
      "client": "claude",
      "routes": [
        "docs/README.md",
        "docs/development/task-context-map.md",
        ".claude/skills"
      ]
    }
  ],
  "maintainerDocs": {
    "index": "docs/README.md",
    "rootDocuments": [
