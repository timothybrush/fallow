        "docs/development/task-context-map.md",
        ".agents/skills"
      ]
    },
    {
      "path": "CLAUDE.md",
      "client": "claude",
      "routes": [
        "docs/README.md",
        "docs/development/task-context-map.md",
        ".claude/skills"
      ]
    }
  ],
